# --- Telegram (obligatoire pour recevoir les alertes) ---
# 1. Sur Telegram, parle à @BotFather -> /newbot -> récupère le token
# 2. Envoie un message à ton bot, puis ouvre :
#    https://api.telegram.org/bot<TON_TOKEN>/getUpdates
#    et copie le "chat":{"id": ...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Ticketmaster (recommandé) ---
# Clé gratuite : https://developer.ticketmaster.com (Discovery API)
TICKETMASTER_API_KEY=
TICKETMASTER_COUNTRY=FR

# --- Viagogo (optionnel) ---
# Viagogo est protégé par un anti-bot AWS WAF : il faut un proxy de scraping
# AVEC rendu JavaScript (render=true). Ex. ScraperAPI (5000 crédits/mois
# gratuits, le rendu JS coûte ~10 crédits/requête) :
# SCRAPER_PROXY_PREFIX=http://api.scraperapi.com?api_key=TA_CLE&render=true&country_code=fr&url=
SCRAPER_PROXY_PREFIX=
# Intervalle minimal entre deux vraies requêtes Viagogo par recherche (en min).
# 240 = 6 requêtes/jour/recherche ≈ 1800 crédits/mois par recherche.
VIAGOGO_MIN_INTERVAL_MINUTES=240

# --- DICE ---
# Pays filtré pour la source DICE (vide = monde entier)
DICE_COUNTRY=FR

# --- Général ---
CHECK_INTERVAL_MINUTES=5
PORT=8400
# DATA_DIR=/data
