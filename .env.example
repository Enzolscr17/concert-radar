# --- Telegram (obligatoire pour recevoir les alertes) ---
# 1. Sur Telegram, parle à @BotFather -> /newbot -> récupère le token
# 2. Envoie un message à ton bot, puis ouvre :
#    https://api.telegram.org/bot<TON_TOKEN>/getUpdates
#    et copie le "chat":{"id": ...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Ticketmaster (recommandé) ---
# Clé gratuite : https://developer.ticketmaster.com (Discovery API)
TICKETMASTER_API_KEY=
TICKETMASTER_COUNTRY=FR

# --- Viagogo (optionnel) ---
# Viagogo est protégé par un anti-bot. Pour le débloquer, utilise un proxy de
# scraping (ex: ScraperAPI, ~1000 requêtes gratuites/mois) :
# SCRAPER_PROXY_PREFIX=http://api.scraperapi.com?api_key=TA_CLE&url=
SCRAPER_PROXY_PREFIX=

# --- DICE ---
# Pays filtré pour la source DICE (vide = monde entier)
DICE_COUNTRY=FR

# --- Général ---
CHECK_INTERVAL_MINUTES=5
PORT=8400
# DATA_DIR=/data
